# Environment variables for LangGraph Financial Analyst with Groq LLM

# Groq LLM Configuration
GROQ_API_KEY=your_groq_api_key_here

# Fallback OpenAI Configuration (if Groq is not available)
OPENAI_API_KEY=your_openai_api_key_here

# API Configuration
API_BASE_URL=http://localhost:8000

# Optional: Database configuration (for future use)
# DATABASE_URL=sqlite:///financial_analyst.db

# Optional: Redis configuration (for caching)
# REDIS_URL=redis://localhost:6379
